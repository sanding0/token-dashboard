# Copy to .env.local — used by Next.js and by pnpm deploy:* (via loadDeployEnv)

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_MAINNET_RPC_URL=
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Browser / wagmi → same-origin proxy (no API key in this value)
NEXT_PUBLIC_SEPOLIA_RPC_URL=/api/rpc/sepolia

# Optional: canonical origin for the RPC proxy allowlist
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Server-only Sepolia upstream (Alchemy/Infura). Used by:
#   - /api/rpc/sepolia proxy
#   - pnpm deploy:sepolia (forge --rpc-url)
# Do NOT put this key in a NEXT_PUBLIC_* variable.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<key>

# Deploy private keys / Etherscan live in contracts/.env — see contracts/.env.example
