# Deploy-only secrets for pnpm deploy:anvil / deploy:sepolia
# (RPC URLs prefer the root .env.local — see ../.env.example)

# --- Anvil (optional — defaults to http://127.0.0.1:8545 + account #0) ---
# ANVIL_RPC_URL=http://127.0.0.1:8545
# ANVIL_DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- Sepolia ---
# Private key may be with or without 0x (deploy script normalizes it).
SEPOLIA_DEPLOYER_PRIVATE_KEY=0x...
# Optional — enables forge --verify
# ETHERSCAN_API_KEY=

# Optional override if you did not set SEPOLIA_RPC_URL in the repo root .env.local:
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<key>
