{
  "name": "wallet-connect-demo",
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky",
    "contracts:build": "forge build --root contracts",
    "abi:export": "node scripts/export-abi.mjs",
    "abi:sync": "pnpm contracts:build && pnpm abi:export",
    "abi:check": "node scripts/check-abi-staged.mjs"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs}": "eslint --fix",
    "contracts/**/*.sol": "forge fmt --root contracts --check"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-query": "^5.101.2",
    "@walletconnect/ethereum-provider": "^2.23.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "~2.54.6",
    "wagmi": "^3.7.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tailwindcss": "^4",
    "typescript": "~5.9.3"
  }
}
